# LLM
OPENAI_API_KEY=sk-your-key-here
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral

# Observability
LANGCHAIN_API_KEY=ls-your-key-here
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=citelens

# MLflow
MLFLOW_TRACKING_URI=./data/mlruns

# Memory
QDRANT_URL=https://your-cluster.qdrant.io
QDRANT_API_KEY=your-qdrant-key
QDRANT_COLLECTION=citelens_papers

PG_DSN=postgresql://user:pass@localhost:5432/citelens

MEM0_API_KEY=your-mem0-key

# Dashboard password (only you know this)
DASHBOARD_PASSWORD=your-secret-password-here

# Google OAuth for dashboard (dashboard_app only)
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8502
DASHBOARD_ALLOWED_EMAILS=your@gmail.com
COOKIE_SECRET=any-random-string-change-this
